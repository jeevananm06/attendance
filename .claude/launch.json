{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd frontend && npx vite --port 5173"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd backend && python -m uvicorn app.main:app --reload --port 8000"],
      "port": 8000
    }
  ]
}
